{
  "name": "goalconnect-monorepo",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "goalconnect-monorepo",
      "version": "0.1.0",
      "workspaces": [
        "packages/*",
        "systems/*"
      ]
    },
    "node_modules/@goalconnect/feature-x": {
      "resolved": "packages/feature-x",
      "link": true
    },
    "node_modules/@goalconnect/feature-y": {
      "resolved": "packages/feature-y",
      "link": true
    },
    "node_modules/@goalconnect/system-member-template": {
      "resolved": "systems/member-template",
      "link": true
    },
    "node_modules/@goalconnect/ui-components": {
      "resolved": "packages/ui-components",
      "link": true
    },
    "node_modules/@goalconnect/utils": {
      "resolved": "packages/utils",
      "link": true
    },
    "packages/feature-x": {
      "name": "@goalconnect/feature-x",
      "version": "0.1.0",
      "dependencies": {
        "@goalconnect/ui-components": "^0.1.0",
        "@goalconnect/utils": "^0.1.0"
      }
    },
    "packages/feature-y": {
      "name": "@goalconnect/feature-y",
      "version": "0.1.0",
      "dependencies": {
        "@goalconnect/ui-components": "^0.1.0",
        "@goalconnect/utils": "^0.1.0"
      }
    },
    "packages/ui-components": {
      "name": "@goalconnect/ui-components",
      "version": "0.1.0"
    },
    "packages/utils": {
      "name": "@goalconnect/utils",
      "version": "0.1.0"
    },
    "systems/member-template": {
      "name": "@goalconnect/system-member-template",
      "version": "0.1.0",
      "dependencies": {
        "@goalconnect/feature-x": "^0.1.0",
        "@goalconnect/feature-y": "^0.1.0"
      }
    }
  }
}
